---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Vielen Dank – Ihre Anfrage wurde gesendet"
  description="Ihre Anfrage bei Freiraum-Auflösungen wurde erfolgreich gesendet. Wir melden uns innerhalb von 24 Stunden."
  robots="noindex, nofollow"
  showStickyCTA={false}
>
  <section class="py-20 md:py-28">
    <div class="container max-w-2xl text-center">
      <div class="bg-success-light rounded-2xl p-8 md:p-12 mb-8">
        <svg class="w-16 h-16 mx-auto mb-6 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <h1 class="text-3xl md:text-4xl font-bold text-ink mb-4">Vielen Dank!</h1>
        <p class="text-lg text-ink-body mb-2">
          Ihre Anfrage wurde erfolgreich gesendet.
        </p>
        <p class="text-ink-body">
          Sie erhalten in Kürze eine Bestätigung per E-Mail. Wir melden uns innerhalb von 24 Stunden bei Ihnen – in der Regel deutlich schneller.
        </p>
      </div>

      <div class="card p-8 text-left">
        <h2 class="text-xl font-bold text-ink mb-4">So geht es weiter</h2>
        <ol class="space-y-4 text-ink-body">
          <li class="flex gap-3">
            <span class="flex-shrink-0 w-8 h-8 bg-accent text-white rounded-full flex items-center justify-center font-bold text-sm">1</span>
            <span>Wir prüfen Ihre Anfrage und melden uns telefonisch oder per E-Mail bei Ihnen.</span>
          </li>
          <li class="flex gap-3">
            <span class="flex-shrink-0 w-8 h-8 bg-accent text-white rounded-full flex items-center justify-center font-bold text-sm">2</span>
            <span>Bei Bedarf vereinbaren wir einen kostenlosen Besichtigungstermin vor Ort.</span>
          </li>
          <li class="flex gap-3">
            <span class="flex-shrink-0 w-8 h-8 bg-accent text-white rounded-full flex items-center justify-center font-bold text-sm">3</span>
            <span>Sie erhalten ein transparentes Festpreisangebot – ohne versteckte Kosten.</span>
          </li>
        </ol>
      </div>

      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="btn btn-primary">Zurück zur Startseite</a>
        <a href="tel:+4930585816730" class="btn btn-secondary">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          Direkt anrufen
        </a>
      </div>
    </div>
  </section>

  {/* Backup conversion tracking: fire generate_lead on page load */}
  <script is:inline>
    // Only fire if not already tracked (prevents double-counting from form redirect)
    if (!sessionStorage.getItem('danke_tracked')) {
      sessionStorage.setItem('danke_tracked', '1');
      // The generate_lead event was already pushed in the form handler before redirect,
      // but this page serves as a reliable URL-based backup for conversion tracking
    }
  </script>
</BaseLayout>
